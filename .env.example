# Embedding provider selection
# EMBEDDING_PROVIDER=mock     (default, no install needed, no semantic meaning)
# EMBEDDING_PROVIDER=local    (sentence-transformers, runs offline, pip install sentence-transformers)
# EMBEDDING_PROVIDER=openai   (OpenAI API, pip install openai)
EMBEDDING_PROVIDER=local

# Optional: set cache directories for the local all-MiniLM-L6-v2 embedder
# HF_HOME=./.hf-cache
# SENTENCE_TRANSFORMERS_HOME=./.sentence-transformers

# Optional: OpenAI embedding configuration
# OPENAI_API_KEY=your-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini API — dùng cho chatbot generation trong app.py
# Lấy key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# Optional: for ChromaDB persistence (bonus task)
# CHROMA_PERSIST_DIR=./chroma_data
